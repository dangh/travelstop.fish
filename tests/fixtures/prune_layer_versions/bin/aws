#!/usr/bin/env bash
# Fake `aws` for prune_layer_versions tests. No network, no real AWS.
# Only `lambda list-layer-versions` is exercised by the function; it prints a
# canned response with 15 versions, newest first (Version 15 .. 1), matching the
# real AWS ordering that the jq/tail/awk pipeline depends on.
if [ "$1" = "lambda" ] && [ "$2" = "list-layer-versions" ]; then
  cat <<'JSON'
{
  "LayerVersions": [
    {"Version": 15},
    {"Version": 14},
    {"Version": 13},
    {"Version": 12},
    {"Version": 11},
    {"Version": 10},
    {"Version": 9},
    {"Version": 8},
    {"Version": 7},
    {"Version": 6},
    {"Version": 5},
    {"Version": 4},
    {"Version": 3},
    {"Version": 2},
    {"Version": 1}
  ]
}
JSON
  exit 0
fi
# Any other aws invocation in tests is a no-op (must never hit the network).
echo "fake-aws: ignoring $*" >&2
exit 0
